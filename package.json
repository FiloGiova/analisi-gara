{
  "name": "fischiolab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FischioLab: webapp per compilare, archiviare ed esportare rapporti arbitrali.",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "seed:admin": "node scripts/create-admin.js",
    "dev": "bash scripts/dev-local.sh",
    "import:legacy-pdfs": "node scripts/import-legacy-pdfs.js",
    "dev:api": "NODE_ENV=development node server.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "test:unit": "node --test tests/fipAdapter.test.js"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@supabase/supabase-js": "^2.110.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "helmet": "^7.2.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.14"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.9.1"
  }
}
