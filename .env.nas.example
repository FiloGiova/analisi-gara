PORT=3000
HOST=0.0.0.0
NODE_ENV=production

STORAGE_DIR=/volume1/rapporti-arbitrali

# Opzionali: se non impostati derivano da STORAGE_DIR
# DATABASE_PATH=/volume1/rapporti-arbitrali/data/rapporti.sqlite
# OUTPUT_DIR=/volume1/rapporti-arbitrali/output

SESSION_COOKIE_NAME=rapporti_sid
SESSION_DAYS=14
COOKIE_SECURE=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-subito
ADMIN_DISPLAY_NAME=Amministratore
