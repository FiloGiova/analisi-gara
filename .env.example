PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Sviluppo locale: dati e PDF restano dentro ./storage
# Sul NAS usa invece .env.nas.example oppure imposta:
# STORAGE_DIR=/volume1/rapporti-arbitrali
STORAGE_DIR=./storage

# Opzionali: se non impostati derivano da STORAGE_DIR
# DATABASE_PATH=./storage/data/rapporti.sqlite
# OUTPUT_DIR=./storage/output

SESSION_SECRET=cambia-con-stringa-casuale-lunga-almeno-32-caratteri
SESSION_COOKIE_NAME=rapporti_sid
SESSION_DAYS=14
COOKIE_SECURE=false

# SMTP per invio email rapporti agli arbitri (opzionale)
# Se SMTP_HOST non è impostato, la funzione di invio email è disabilitata.
# Per Gmail: usa una App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Rapporti Arbitrali <tuoindirizzo@gmail.com>

# Usati dagli script di setup/seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-subito
ADMIN_DISPLAY_NAME=Amministratore
