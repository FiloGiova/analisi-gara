PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Sviluppo locale: dati e PDF restano dentro ./storage
# Sul NAS usa invece .env.nas.example oppure imposta:
# STORAGE_DIR=/volume1/rapporti-arbitrali
STORAGE_DIR=./storage

# Opzionali: se non impostati derivano da STORAGE_DIR
# DATABASE_PATH=./storage/data/rapporti.sqlite
# OUTPUT_DIR=./storage/output

# --- Produzione cloud (Supabase + Render) ---
# Database Postgres di Supabase: Project Settings → Database → Connection string (URI).
# Se DATABASE_URL è impostato, l'app usa Postgres; altrimenti resta su SQLite locale.
DATABASE_URL=
DATABASE_SSL=true
PG_POOL_MAX=5
# Supabase Storage per PDF e foto: Project Settings → API.
# Se SUPABASE_URL e SUPABASE_SERVICE_KEY sono impostati, i file vanno su Storage;
# altrimenti restano sul filesystem sotto STORAGE_DIR.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET=rapporti

SESSION_SECRET=cambia-con-stringa-casuale-lunga-almeno-32-caratteri
SESSION_COOKIE_NAME=rapporti_sid
SESSION_DAYS=14
COOKIE_SECURE=false

# SMTP per invio email rapporti agli arbitri (opzionale)
# Se SMTP_HOST non è impostato, la funzione di invio email è disabilitata.
# Per Gmail: usa una App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FischioLab <tuoindirizzo@gmail.com>

# Usati dagli script di setup/seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-subito
ADMIN_DISPLAY_NAME=Amministratore

# Funzionalità AI: usa Anthropic Claude per generare/raffinare il giudizio globale.
# Quando false (o assente), le route /api/ai/* non sono montate e l'helper AI
# non viene renderizzato lato client. Per attivarla impostare true e fornire ANTHROPIC_API_KEY.
ENABLE_AI_FEATURES=false
ANTHROPIC_API_KEY=
